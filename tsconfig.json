{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@public/*": ["./public/*"],
      "@styles/*": ["./src/styles/*"],
      "@components/*": ["./src/common/components/*"],
      "@hocs/*": ["./src/common/hocs/*"],
      "@enums/*": ["./src/common/enums/*"],
      "@interfaces/*": ["./src/common/interfaces/*"],
      "@dtos/*": ["./src/common/dtos/*"],
      "@utils/*": ["./src/common/utils/*"],
      "@core/*": ["./src/core/*"],
      "@graphql/*": ["./src/graphql/*"],
      "@pothos": ["./src/graphql/pothos.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "environment.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
