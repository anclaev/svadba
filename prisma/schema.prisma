generator client {
  provider = "prisma-client-js"
}

generator pothos {
  provider      = "prisma-pothos-types"
  clientOutput  = "@prisma/client"
  output        = "./pothos.ts"
  prismaUtils   = true
  documentation = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Пол гостя
enum Sex {
  /// Мужчина
  MALE
  /// Женщина
  FEMALE
}

/// Возраст гостя
enum Age {
  /// Взрослый
  ADULT
  /// Ребёнок
  CHILD
}

/// Статус гостя
enum Status {
  /// Ожидает подтверждения
  PENDING
  /// Подтверждён
  APPROVED
  /// Администратор
  ADMIN
}

/// Сторона гостя
enum Side {
  /// Жених
  GROOM
  /// Невеста
  BRIDE
}

/// Тип гостя
enum Type {
  /// Коллега
  COLLEAGUE
  /// Друг
  FRIEND
  /// Лучший друг
  BEST_FRIEND
  /// Родственник
  RELATIVE
  /// Близкий родственник
  CLOSE_RELATIVE
  /// Родитель
  PARENT
}

/// Аккаунт в системе
model Account {
  /// ID аккаунта
  id     String @id @default(uuid())
  /// Статус аккаунта
  status Status @default(PENDING)

  /// Пароль аккаунта
  password String

  /// Почта аккаунта
  email String @unique

  /// Семья аккаунта
  family Family?

  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
}

/// Приглашённая семья
model Family {
  /// ID семьи
  id String @id @default(uuid())

  /// Название семьи
  name String

  /// Глава семьи
  owner Account @relation(fields: [ownerId], references: [id])

  /// ID аккаунта
  ownerId String @unique

  /// Члены семьи (гости)
  members Guest[]

  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
}

/// Гость мероприятия
model Guest {
  /// ID гостя
  id String @id @default(uuid())

  /// Имя гостя
  first_name String

  /// Фамилия гостя
  last_name String?

  /// Сторона (жених/невеста) гостя
  side  Side
  /// Тип гостя
  type  Type @default(RELATIVE)
  /// Возраст гостя
  age   Age  @default(ADULT)
  /// Пол гостя
  sex   Sex
  /// Номер стола
  table Int?

  /// Нужен ли трансфер гостю
  transfer      Boolean @default(false)
  /// Нужно ли проживание гостю
  accommodation Boolean @default(false)

  /// На каких частях мероприятия будет гость
  events Event[]

  /// Семья гостя
  family Family @relation(fields: [familyId], references: [id])

  /// ID семьи гостя
  familyId String

  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
}

/// Мероприятие события
model Event {
  /// ID мероприятия
  id    String @id @default(uuid())
  /// Порядковый номер мероприятия
  index Int    @unique

  /// Короткое название мероприятия (транслит)
  alias String @unique

  /// Название мероприятия
  name String

  /// Дата мероприятия
  date DateTime @db.Date()

  /// Время начала мероприятия
  start DateTime @db.Time()

  /// Время окончания мероприятия
  end DateTime @db.Time()

  /// Описание мероприятия
  description String

  /// Адрес проведения мероприятия
  address String?

  /// Ссылка на материалы мероприятия
  url String?

  /// Гости, участвующие в мероприятии
  guests Guest[]

  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
}
