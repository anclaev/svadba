generator client {
  provider = "prisma-client-js"
}

generator pothos {
  provider      = "prisma-pothos-types"
  clientOutput  = "@prisma/client"
  output        = "./pothos.ts"
  prismaUtils   = true
  documentation = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Пол гостя
enum Sex {
  /// Мужчина
  MALE
  /// Женщина
  FEMALE
}

/// Возраст гостя
enum Age {
  /// Взрослый
  ADULT
  /// Ребёнок
  CHILD
}

/// Статус гостя
enum Status {
  /// Ожидает подтверждения
  PENDING
  /// Подтверждён
  APPROVED
  /// Администратор
  ADMIN
}

/// Сторона гостя
enum Side {
  /// Жених
  GROOM
  /// Невеста
  BRIDE
}

/// Тип гостя
enum Type {
  /// Коллега
  COLLEAGUE
  /// Друг
  FRIEND
  /// Лучший друг
  BEST_FRIEND
  /// Родственник
  RELATIVE
  /// Близкий родственник
  CLOSE_RELATIVE
  /// Родитель
  PARENT
}

model Family {
  id        String   @id @default(uuid()) @db.Uuid
  ownerId   String   @unique @db.Uuid
  name      String
  owner     Guest    @relation("FamilyOwner", fields: [ownerId], references: [id])
  members   Guest[]  @relation("FamilyMember")
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
}

model Guest {
  id            String   @id @default(uuid()) @db.Uuid
  familyId      String?  @db.Uuid
  status        Status   @default(PENDING)
  password      String
  email         String   @unique
  first_name    String
  last_name     String?
  side          Side
  type          Type     @default(RELATIVE)
  age           Age      @default(ADULT)
  sex           Sex
  table         Int?
  transfer      Boolean  @default(false)
  accommodation Boolean  @default(false)
  family        Family?  @relation("FamilyMember", fields: [familyId], references: [id])
  ownedFamily   Family?  @relation("FamilyOwner")
  events        Event[]
  createdAt     DateTime @default(now()) @db.Date
  updatedAt     DateTime @updatedAt @db.Date
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  index       Int      @unique @db.Integer
  alias       String   @unique
  name        String
  date        DateTime @db.Date()
  start       DateTime @db.Time(2)
  end         DateTime @db.Time(2)
  description String
  address     String?
  url         String?
  guests      Guest[]
  createdAt   DateTime @default(now()) @db.Date
  updatedAt   DateTime @updatedAt @db.Date
}
