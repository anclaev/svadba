generator client {
  provider = "prisma-client-js"
}

generator pothos {
  provider      = "prisma-pothos-types"
  output        = "./pothos.ts"
  prismaUtils   = true
  documentation = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Пол гостя
enum Sex {
  /// Мужчина
  MALE
  /// Женщина
  FEMALE
}

/// Возраст гостя
enum Age {
  /// Взрослый
  ADULT
  /// Ребёнок
  CHILD
}

/// Статус гостя
enum Status {
  /// Ожидает подтверждения
  PENDING
  /// Подтверждён
  APPROVED
  /// Администратор
  ADMIN
}

/// Сторона гостя
enum Side {
  /// Жених
  GROOM
  /// Невеста
  BRIDE
}

/// Тип гостя
enum Type {
  /// Коллега
  COLLEAGUE
  /// Друг
  FRIEND
  /// Лучший друг
  BEST_FRIEND
  /// Родственник
  RELATIVE
  /// Близкий родственник
  CLOSE_RELATIVE
  /// Родитель
  PARENT
}

model Account {
  id       String @id @default(uuid())
  status   Status @default(PENDING)
  password String
  email    String @unique

  family Family?

  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
}

model Family {
  id String @id @default(uuid())

  name String

  owner   Account @relation(fields: [ownerId], references: [id])
  ownerId String  @unique

  members Guest[]

  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
}

model Guest {
  id String @id @default(uuid())

  first_name String
  last_name  String?

  /// Сторона (жених/невеста) гостя
  side  Side
  /// Тип гостя
  type  Type @default(RELATIVE)
  /// Возраст гостя
  age   Age  @default(ADULT)
  /// Пол гостя
  sex   Sex
  /// Номер стола
  table Int?

  /// Нужен ли трансфер гостю
  transfer      Boolean @default(false)
  /// Нужно ли проживание гостю
  accommodation Boolean @default(false)

  /// На каких частях мероприятия будет гость
  events Event[]

  family   Family @relation(fields: [familyId], references: [id])
  familyId String

  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
}

model Event {
  id    String @id @default(uuid())
  /// Порядковый номер мероприятия
  index Int    @unique

  alias String @unique
  name  String

  time        DateTime @db.Date
  description String
  address     String?
  url         String?

  guests Guest[]

  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date
}
