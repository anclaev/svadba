{
  "name": "anclaev-svadba",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky",
    "commit": "npx git-cz",
    "push": "git push --follow-tags origin && git push --follow-tags gitverse",
    "changelog": "npx conventional-changelog -p nextjs -i CHANGELOG.md -s",
    "release": "npx standard-version -s --release-as",
    "prisma:local": "dotenv -e .env.local yarn prisma",
    "depcheck": "depcheck ."
  },
  "dependencies": {
    "@apollo/client": "^3.11.4",
    "@nextui-org/navbar": "^2.0.36",
    "@nextui-org/react": "^2.4.6",
    "@pothos/core": "^4.2.0",
    "@pothos/plugin-errors": "^4.2.0",
    "@pothos/plugin-prisma": "^4.2.1",
    "@pothos/plugin-prisma-utils": "^1.2.0",
    "@pothos/plugin-relay": "^4.1.0",
    "@pothos/plugin-zod": "^4.1.0",
    "@prisma/client": "^5.18.0",
    "bcrypt": "^5.1.1",
    "cyrillic-to-translit-js": "^3.2.1",
    "framer-motion": "^11.3.28",
    "graphql": "^16.9.0",
    "graphql-scalars": "^1.23.0",
    "graphql-yoga": "^5.6.3",
    "next": "14.2.5",
    "next-auth": "^5.0.0-beta.20",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.2.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "auth": "^1.1.1",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "depcheck": "^1.4.7",
    "dotenv": "^16.4.5",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8",
    "nextui-cli": "^0.3.4",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "prisma": "^5.18.0",
    "prisma-generator-pothos-codegen": "^0.7.0",
    "standard-version": "^9.5.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.(ts|tsx|sass|css)": [
      "prettier --write"
    ],
    "*.md": "prettier --write"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog",
      "disableScopeLowerCase": true,
      "disableSubjectLowerCase": true
    }
  }
}
